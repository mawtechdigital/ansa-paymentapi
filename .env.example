# ============================================================
# DATABASE
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=payment_db

# ============================================================
# REVENUE MONSTER
# ============================================================
# URLs are auto-set based on NODE_ENV:
#   sandbox    → sb-oauth / sb-open .revenuemonster.my
#   production → oauth / open .revenuemonster.my

RM_CLIENT_ID=your_client_id_here
RM_CLIENT_SECRET=your_client_secret_here
RM_STORE_ID=your_store_id_here
RM_PRIVATE_KEY_PATH=./private_key_revenuemonster.pem

# Your server's callback endpoint (RM posts here after payment)
RM_NOTIFY_URL=https://your-domain.com/api/payment/rm-callback

# Where customer browser redirects after payment
RM_REDIRECT_URL=https://your-site.com/payment/complete

# Checkout layout version
RM_LAYOUT_VERSION=v4

# ============================================================
# ENCRYPTION
# ============================================================
ENCRYPTION_SECRET_KEY=change-this-to-random-words-keep-it-secret

# ============================================================
# APP
# ============================================================
PORT=3000
